{
  "name": "sharanya-borewell-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_OPTIONS=--use-system-ca node --watch src/server.js",
    "build": "prisma generate && prisma migrate deploy",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "prisma migrate deploy && prisma db seed",
    "db:reset-crdb-public": "node scripts/crdb-reset-public-schema.mjs",
    "seed:geo": "node scripts/seed-districts-mandals-from-geo-json.mjs",
    "flush-db": "node scripts/flush-db.mjs",
    "flush-db:all": "node scripts/flush-db.mjs --all"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.0",
    "prisma": "7.8.0"
  }
}
