# --- HTTP (Express) ---
PORT=5000

# --- Database (PostgreSQL / Cockroach) ---
# Schema: use `npm run db:migrate` (Prisma Migrate). Raw `prisma db push` can fail on Cockroach Cloud (crdb_internal_region enum).
# Recovery: `npm run db:reset-crdb-public` then `npm run db:migrate` (wipes app tables + migration history in `public`).
#
# Prefer DATABASE_URL from your host (includes host + port + SSL). If unset, URL is built from DB_* + DB_PORT.
# Railway / Cockroach Cloud: set only DATABASE_URL + JWT_* + CORS_ORIGIN — DB_HOST is not required when DATABASE_URL is set.
#
# SQL port: use DB_PORT or db_port only. Never put the DB port in PORT — PORT is only the API server.
# Defaults to 5432 when DB_PORT / db_port are omitted (typical local Postgres). Cockroach Cloud: usually 26257.
#
# DB_PORT=26257
# db_port=26257
# DB_SSL=false

DATABASE_URL="postgresql://USER:PASSWORD@HOST:26257/DATABASE?sslmode=require"

# If you omit DATABASE_URL:
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=defaultdb

JWT_SECRET=replace-with-32-plus-char-secret-string
JWT_REFRESH_SECRET=replace-with-different-32-plus-char-secret
CORS_ORIGIN=http://localhost:5173
