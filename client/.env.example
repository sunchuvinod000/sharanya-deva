# Variable name must be exactly VITE_API_URL (Vite only exposes env vars that start with VITE_).
#
# `npm run dev` (local): create client/.env or .env.local with VITE_API_URL=… and restart the dev server.
# If you omit it locally, the app uses /api and Vite proxies to 127.0.0.1:5000 (vite.config.js) — not your Vercel URL.
#
# Vercel (frontend project): set VITE_API_URL in Project Settings → Environment Variables, then redeploy
# so `npm run build` embeds it. Old deploys still contain whatever URL was baked in at build time.
VITE_API_URL=https://sharanya-deva.vercel.app/api
